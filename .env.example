# Server binding.
# Native installs bind the app to this host/port.
# Docker installs use ORCHESTRATOR_PORT as the host port while the container
# itself still listens on 3000.
# Keep local by default. Use 0.0.0.0 only behind auth, VPN, or a trusted reverse proxy.
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=3000

# Browser agent live view.
# macOS runs Patchright headful locally. Linux/Docker uses Xvnc + noVNC.
# Docker installs use BROWSER_AGENT_VNC_WS_PORT as the host port while the
# container itself still listens on 6080.
BROWSER_AGENT_LIVE_VIEW=1
BROWSER_AGENT_VNC_WS_HOST=127.0.0.1
BROWSER_AGENT_VNC_WS_PORT=6080
BROWSER_AGENT_VNC_WS_PUBLIC_URL=ws://127.0.0.1:6080

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional market data for Watchlist financial search, quotes, and history.
TWELVE_DATA_API_KEY=

# Optional Google Workspace OAuth.
# Redirect URI defaults to <app_origin>/api/integrations/google/oauth/callback.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=
GMAIL_OAUTH_REDIRECT_URI=

# Optional Home Assistant.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Optional WhatsApp browser executable override.
WHATSAPP_CHROME_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=

# Optional managed update repository override.
ORCHESTRATOR_UPDATE_REPO_OWNER=Horia73
ORCHESTRATOR_UPDATE_REPO_NAME=orchestrator
# Optional token for private GitHub release lookup in Settings > Updates.
ORCHESTRATOR_UPDATE_GITHUB_TOKEN=

# Docker installer only: set automatically by scripts/install.sh.
# Lets Settings > Updates ask the host to pull, rebuild, and restart Compose.
ORCHESTRATOR_DOCKER_UPDATE_URL=
ORCHESTRATOR_DOCKER_UPDATE_TOKEN=
