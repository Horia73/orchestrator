# Server binding.
# Native installs bind the app to this host/port.
# Docker installs use ORCHESTRATOR_PORT as the host port while the container
# itself still listens on 3000.
# Keep local by default. Use 0.0.0.0 only behind auth, VPN, or a trusted reverse proxy.
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=3000
# Optional bearer/header/cookie token for direct API clients. Browser same-origin
# requests still work locally; non-browser API calls to non-loopback hosts need
# this token.
ORCHESTRATOR_API_TOKEN=
# Docker-only local proxy/gateway ranges allowed to forward loopback host checks.
# The compose default covers Docker bridge networks while keeping public clients blocked.
ORCHESTRATOR_TRUSTED_LOOPBACK_FORWARDERS=
# Public/LAN URL that users open in the browser.
# Leave empty for auto-detection from Host/X-Forwarded-* headers.
# Google OAuth redirects use this only when it is localhost or a public HTTPS
# domain. .lan/.local/private IP origins fall back to localhost for SSH tunnels.
# For a manually managed custom domain, set this to the final HTTPS origin
# after DNS, TLS, and the reverse proxy are configured.
ORCHESTRATOR_PUBLIC_URL=
# Optional hints used to show exact SSH tunnel commands in Settings/runtime context.
ORCHESTRATOR_SSH_USER=
ORCHESTRATOR_SSH_HOST=
ORCHESTRATOR_HOST_LAN_IP=
# Installer-only public HTTPS setup. These are read by scripts/install.sh when
# ORCHESTRATOR_PUBLIC_HTTPS_SETUP=duckdns; the app itself only needs
# ORCHESTRATOR_PUBLIC_URL after setup.
ORCHESTRATOR_PUBLIC_HTTPS_SETUP=
ORCHESTRATOR_DUCKDNS_DOMAIN=
ORCHESTRATOR_DUCKDNS_TOKEN=
ORCHESTRATOR_LETSENCRYPT_EMAIL=

# Browser agent live view.
# Browser agent always uses Patchright. Docker installs use
# BROWSER_AGENT_VNC_WS_PORT as the host port while the container itself still
# listens on 6080.
BROWSER_AGENT_ALLOW_NO_SANDBOX=1
BROWSER_AGENT_LIVE_VIEW=1
BROWSER_AGENT_VNC_WS_HOST=127.0.0.1
BROWSER_AGENT_VNC_WS_PORT=6080
# For custom-domain HTTPS, proxy /vnc/ to BROWSER_AGENT_VNC_WS_PORT and set:
# BROWSER_AGENT_VNC_WS_PUBLIC_URL=wss://your-domain.example/vnc
BROWSER_AGENT_VNC_WS_PUBLIC_URL=ws://127.0.0.1:6080

# AI providers
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional market data for Watchlist financial search, quotes, and history.
TWELVE_DATA_API_KEY=

# Optional Google Maps Platform key for Smart Maps, Geocoding, Places, Routes,
# Static Maps, and Google Weather/Air Quality/Pollen upgrades.
GOOGLE_MAPS_API_KEY=
# Recommended for production Smart Maps tilt/rotation: create a JavaScript
# Vector Map ID with Tilt and Rotation enabled in Google Map Management.
GOOGLE_MAPS_MAP_ID=

# Optional Google Workspace OAuth.
# Redirect URI defaults to a Google-compatible callback:
# - http://localhost:3000/... for local/SSH-tunnel setup
# - https://your-public-domain/... when ORCHESTRATOR_PUBLIC_URL is public HTTPS
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_WORKSPACE_OAUTH_REDIRECT_URI=
GMAIL_OAUTH_REDIRECT_URI=

# Optional Home Assistant.
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Optional WhatsApp provider. Default is baileys. Use wwebjs for the legacy
# browser-backed provider, or disabled as an emergency kill switch.
WHATSAPP_PROVIDER=baileys
# Optional legacy WhatsApp browser executable override (used only with
# WHATSAPP_PROVIDER=wwebjs).
WHATSAPP_CHROME_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=
WHATSAPP_USER_AGENT=

# Optional managed update repository override.
ORCHESTRATOR_UPDATE_REPO_OWNER=Horia73
ORCHESTRATOR_UPDATE_REPO_NAME=orchestrator
# Optional token for private GitHub release lookup in Settings > Updates.
ORCHESTRATOR_UPDATE_GITHUB_TOKEN=

# Docker installer only: set automatically by scripts/install.sh. Lets the
# container call a token-protected helper on the host for operations that cannot
# run reliably inside Docker, such as managed updates and Claude Code usage.
ORCHESTRATOR_HOST_BRIDGE_URL=
ORCHESTRATOR_HOST_BRIDGE_TOKEN=
# Backward-compatible managed update endpoint.
ORCHESTRATOR_DOCKER_UPDATE_URL=
ORCHESTRATOR_DOCKER_UPDATE_TOKEN=

# Docker bind mount paths. Set automatically by scripts/install.sh.
# ORCHESTRATOR_DATA_DIR maps to /app/.orchestrator inside the container — all
# runtime data (SQLite, uploads, browser profiles, workspace files) lives here.
# ORCHESTRATOR_NODE_HOME maps to /home/node — npm and Playwright caches.
# ORCHESTRATOR_SELF_DEV_HOST_SOURCE_DIR maps the host git checkout into the
# container at /orchestrator-source so self-development can create git
# worktrees even though /app is a built image copy without .git metadata.
# Leave empty for standalone dev; docker-compose.yml then creates
# ./.orchestrator-data and ./.orchestrator-node-home and mounts the compose
# directory as the self-dev source checkout.
ORCHESTRATOR_DATA_DIR=
ORCHESTRATOR_NODE_HOME=
ORCHESTRATOR_SELF_DEV_HOST_SOURCE_DIR=
# UID/GID the container runs as. install.sh sets these to the host user so
# bind-mounted files are owned by you, not by uid 1000. Defaults to 1000:1000
# (the `node` user baked into the image) for standalone dev.
ORCHESTRATOR_UID=
ORCHESTRATOR_GID=
