{
  "name": "orchestrator",
  "version": "1.0.14",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "predev": "lsof -ti :3000 | xargs kill -9 2>/dev/null; rm -f .next/dev/lock; true",
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "browsers:install": "patchright install chromium",
    "reset:agent-files": "tsx scripts/reset-agent-files.ts",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "mcp": "tsx mcp-server/server.ts",
    "postinstall": "find node_modules/node-pty/prebuilds -name spawn-helper -exec chmod +x {} + 2>/dev/null; true"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@novnc/novnc": "^1.7.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.5.0",
    "isomorphic-dompurify": "^3.12.0",
    "katex": "^0.16.38",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "patchright": "^1.59.4",
    "pdfjs-dist": "^5.5.207",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "whatsapp-web.js": "^1.34.7",
    "ws": "^8.20.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
